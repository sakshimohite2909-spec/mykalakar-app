rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── events ───────────────────────────────────────────────────────────────
    match /events/{id} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
    }

    // Public directory metadata used by discovery and location flows.
    match /categories/{id} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
    }

    match /states/{id} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── artists ──────────────────────────────────────────────────────────────
    match /artists/{id} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == id;
    }

    // ── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    match /users/{uid}/{document=**} {
      allow read, write: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    // Artist registration writes applications before admin approval.
    match /artist_applications/{id} {
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAuth() && isAdmin();
    }

    // ── inquiries ────────────────────────────────────────────────────────────
    match /inquiries/{id} {
      allow read: if isAuth() && (resource.data.customerId == request.auth.uid || resource.data.artistId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update, delete: if isAuth() && isAdmin();
    }

    // ── bookings ─────────────────────────────────────────────────────────────
    match /bookings/{id} {
      allow read: if isAuth() && (resource.data.customerId == request.auth.uid || resource.data.artistId == request.auth.uid || isAdmin());
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && (resource.data.artistId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && isAdmin();
    }

    // ── admin_requests ───────────────────────────────────────────────────────
    match /admin_requests/{id} {
      allow create: if isAuth();
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAuth() && isAdmin();
    }

    // ── admins ───────────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── master_data ──────────────────────────────────────────────────────────
    match /master_data/{document=**} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAuth() && isAdmin();
    }
  }
}
